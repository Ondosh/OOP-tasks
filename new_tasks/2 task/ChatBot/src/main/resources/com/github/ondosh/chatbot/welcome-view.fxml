<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.github.ondosh.chatbot.controller.WelcomeController"
      spacing="15" alignment="CENTER"
      style="-fx-padding: 40;">

    <Label text="Добро пожаловать!" style="-fx-font-size: 18px;"/>
    <Label text="Введите ваше имя:"/>

    <TextField fx:id="nameField" promptText="Ваше имя"
               maxWidth="200"
               onAction="#onStartChat"/>

    <Button text="Начать чат" onAction="#onStartChat"
            defaultButton="true"/>

</VBox>