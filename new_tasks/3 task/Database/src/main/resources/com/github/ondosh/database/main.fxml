<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0"
      prefWidth="800"
      prefHeight="600"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.github.ondosh.database.controller.MainController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>

    <HBox spacing="10.0">
        <Button text="Добавить" onAction="#onAddButton"/>
        <Button text="Изменить" onAction="#onEditButton"/>
        <Button text="Удалить"  onAction="#onDeleteButton"/>
        <Label text="Сортировать по:"/>
        <ComboBox fx:id="sortComboBox" onAction="#onSortChanged"/>
    </HBox>

    <TableView fx:id="gamesTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn"  text="Название"/>
            <TableColumn fx:id="genreColumn"  text="Жанр"/>
            <TableColumn fx:id="priceColumn"  text="Цена"/>
            <TableColumn fx:id="ratingColumn" text="Рейтинг"/>
        </columns>
    </TableView>

    <Label fx:id="statusLabel" text="Готово"/>
</VBox>